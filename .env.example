# ─────────────────────────────────────────────────────────────────────────────
# AutoHaus — environment variables
# Copy this file to `.env` (local) and set the same keys in Vercel → Project →
# Settings → Environment Variables (Production + Preview).
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL / Neon) ─────────────────────────────────────────────
# Create a free Postgres database at https://neon.tech and copy both strings
# from the dashboard "Connect" panel:
#   DATABASE_URL → "Pooled connection" ON  (host contains "-pooler"). App runtime.
#   DIRECT_URL   → "Pooled connection" OFF (direct host).            Migrations.
# Keep ?sslmode=require on both.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require"

# ── Better Auth ──────────────────────────────────────────────────────────────
# Generate a strong secret with:  openssl rand -hex 32
BETTER_AUTH_SECRET="replace-with-a-32-byte-hex-secret"

# Public URL of the app.
#   Local:      http://localhost:3000
#   Production: https://your-domain.com  (or your *.vercel.app URL)
# On Vercel you can leave these unset — the app falls back to VERCEL_URL — but
# setting BETTER_AUTH_URL to your final domain is recommended for stable cookies.
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── File storage (Cloudflare R2) ─────────────────────────────────────────────
# Admin image/audio uploads. Leave EMPTY for local dev (writes to /public/uploads).
# Set all five in production so uploads persist (Vercel's disk is read-only).
# Cloudflare R2 free tier: 10 GB storage + no egress fees. Setup (see README):
#   1. dash.cloudflare.com → R2 → Create bucket (e.g. "autohaus").
#   2. Bucket → Settings → Public access → enable r2.dev URL (or add a custom
#      domain). Copy that URL into R2_PUBLIC_URL.
#   3. R2 → Manage API Tokens → Create token (Object Read & Write) → copy keys.
#   4. R2_ACCOUNT_ID is the hex id in your R2 dashboard URL / "Account details".
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="autohaus"
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxxxxxx.r2.dev"

# ── First admin (only used by `pnpm db:seed:admin`) ──────────────────────────
# Optional overrides; safe defaults exist in scripts/seed-admin.mjs.
# ADMIN_EMAIL="you@example.com"
# ADMIN_PASSWORD="change-me-after-first-login"
# ADMIN_NAME="Super Admin"
